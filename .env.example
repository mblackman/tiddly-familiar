# Familiar gateway configuration (env-only). Copy to .env and fill in.

# Shared secret the plugin sends as the X-API-Key header. Required by the
# gateway process; leave the plugin's API key setting empty to run without one.
GATEWAY_API_KEY=change-me

# --- Generation backend: Gemini (default) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# --- Fully-local generation via Ollama (optional) ---
# Set LLM_BACKEND=ollama to skip Gemini entirely; compose then pulls the model.
# LLM_BACKEND=ollama
# OLLAMA_LLM_MODEL=llama3.2
# OLLAMA_URL=http://ollama:11434

# --- Embeddings / retrieval ---
EMBED_MODEL=nomic-embed-text
RAG_TOP_K=8

# Rewrite chat follow-ups into a standalone retrieval query before ranking
# (one extra generation call per follow-up). Set to false to disable.
# RAG_QUERY_REWRITE=true

# Where persistent caches (embeddings + note cache) live inside the container.
PROFILES_DIR=/app/profiles
